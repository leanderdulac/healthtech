# Google Cloud Platform
GCP_PROJECT_ID=seu-projeto-gcp
GCP_LOCATION=us-central1

# Vertex AI
VERTEX_ENDPOINT_ID=projects/SEU_PROJETO/locations/us-central1/endpoints/SEU_ENDPOINT
VERTEX_MODEL_NAME=projects/SEU_PROJETO/locations/us-central1/models/SEU_MODELO
VERTEX_MACHINE_TYPE=n1-standard-4

# Cloud Storage
GCS_STAGING_BUCKET=gs://seu-projeto-vertex-staging
GCS_INPUT_DATA=gs://seu-bucket/vertex-input/batch_input.jsonl
GCS_OUTPUT_DATA=gs://seu-bucket/vertex-output/

# BigQuery
BQ_DATASET=healthtech_datalake
BQ_LOCATION=US

# Ambiente: development | production
ENVIRONMENT=development

# Segurança
# Gere com: openssl rand -hex 32
SECRET_SALT=altere-este-salt-em-producao
API_KEY=
# true apenas em dev local — ignorado em production
AUTH_DISABLED=false
# Lista separada por vírgula. Em produção, defina explicitamente (nunca *).
CORS_ORIGINS=http://localhost:8000,http://localhost:8080,http://localhost:8501


# FHIR / HL7
FHIR_VERSION=R4
FHIR_EXPORT_DIR=data/fhir_exports
FHIR_IG_BASE=http://healthtech.local/fhir
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_SERVER_TOKEN=
CLINICAL_CACHE_DIR=data/clinical_cache
CLINICAL_SYNC_BATCH_SIZE=50

# Ingestão Real
APPLE_HEALTH_EXPORT_PATH=data/ingestion/apple_health/export.xml
APPLE_HEALTH_PATIENT_ID=PAT-APPLE-001
GOOGLE_FIT_ACCESS_TOKEN=
GOOGLE_FIT_CACHE_PATH=data/ingestion/google_fit/cache.json
GOOGLE_FIT_PATIENT_ID=PAT-GFIT-001
BLE_DEVICE_ADDRESS=
BLE_PATIENT_ID=PAT-BLE-001
BLE_USE_STUB=true

# Vertex TCN Deploy
VERTEX_TCN_ENDPOINT_ID=projects/SEU_PROJETO/locations/us-central1/endpoints/SEU_TCN_ENDPOINT
GCS_MODEL_BUCKET=seu-projeto-vertex-staging
VERTEX_SERVING_CONTAINER=us-docker.pkg.dev/vertex-ai/prediction/pytorch-gpu.2-0:latest

# Scraper USP Teses
SCRAPER_DELAY=1.5
SCRAPER_MAX_PAGES=0
SCRAPER_MAX_DETAILS=0
